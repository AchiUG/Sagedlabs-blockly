    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed:safe": "tsx --require dotenv/config scripts/safe-seed.ts",
    "db:seed:all": "tsx --require dotenv/config scripts/seed-all.ts",
    "db:init": "prisma generate && prisma db push && tsx --require dotenv/config scripts/seed-all.ts"
  },
  "prisma": {
    "seed": "pnpm tsx --require dotenv/config scripts/seed-all.ts"
