generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  firstName             String?
  lastName              String?
  role                  UserRole               @default(STUDENT)
  bio                   String?
  institution           String?
  archetype             String?
  archetypeSecondary    String?
  pathwayType           String?
  onboardingCompleted   Boolean                @default(false)
  onboardingStep        String?
  subscriptionTier      String?
  subscriptionStatus    String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  walletAddress         String?
  walletEnabled         Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  groupId               String?
  accounts              Account[]
  activities            Activity[]             @relation("UserActivities")
  submissions           AssignmentSubmission[]
  blocksProjects        BlocksProject[]
  blocksSubmissions     BlocksSubmission[]
  certificates          Certificate[]
  communityImpacts      CommunityImpact[]      @relation("UserCommunityImpacts")
  contributions         Contribution[]         @relation("UserContributions")
  coursesCreated        Course[]               @relation("CourseInstructor")
  earnDownRecords       EarnDownRecord[]       @relation("UserEarnDowns")
  enrollments           Enrollment[]
  forumPosts            ForumPost[]
  forumReplies          ForumReply[]
  masteryRecords        MasteryRecord[]
  progress              Progress[]
  resilienceScore       ResilienceScore?
  sagedTokens           SAGEDToken[]           @relation("UserSAGEDTokens")
  svuBalance            SVUBalance?
  sessions              Session[]
  skillProgress         SkillProgress[]
  tokenTransactions     TokenTransaction[]
  group                 Group?                 @relation(fields: [groupId], references: [id])
  userBadges            UserBadge[]
  checkpoints           UserCheckpoint[]
  gamification          UserGamification?
  learningPaths         UserLearningPath[]
  verifications         Verification[]         @relation("VerifierActivities")
}

model Group {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  courseId    String?
  maxMembers  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course?  @relation(fields: [courseId], references: [id])
  members     User[]

  @@index([code])
  @@index([courseId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id                 String           @id @default(cuid())
  title              String
  description        String
  shortDescription   String?
  imageUrl           String?
  level              CourseLevel
  learningStage      Int?
  duration           String
  prerequisites      String?
  learningObjectives String[]
  price              Float            @default(0)
  isPublished        Boolean          @default(false)
  instructorId       String
  categoryId         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  certificates       Certificate[]
  category           Category?        @relation(fields: [categoryId], references: [id])
  instructor         User             @relation("CourseInstructor", fields: [instructorId], references: [id])
  earnDownRecords    EarnDownRecord[] @relation("CourseEarnDowns")
  enrollments        Enrollment[]
  forumPosts         ForumPost[]
  groups             Group[]
  modules            Module[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  courses     Course[]
}

model Module {
  id          String       @id @default(cuid())
  title       String
  description String?
  orderIndex  Int
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  lessons     Lesson[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id           String     @id @default(cuid())
  title        String
  content      String
  videoUrl     String?
  thumbnailUrl String?
  duration     Int?
  orderIndex   Int
  moduleId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress     Progress[]
}

model Assignment {
  id          String                 @id @default(cuid())
  title       String
  description String
  type        AssignmentType
  dueDate     DateTime?
  maxScore    Int                    @default(100)
  orderIndex  Int
  moduleId    String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  module      Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  content      String?
  fileUrl      String?
  score        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  assignmentId String
  userId       String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Progress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  completed    Boolean  @default(false)
  timeSpent    Int      @default(0)
  lastAccessed DateTime @default(now())
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Certificate {
  id              String          @id @default(cuid())
  userId          String
  courseId        String?
  certificateType CertificateType @default(COURSE)
  stageLevel      Int?
  stageLevelTitle String?
  issuedAt        DateTime        @default(now())
  certificateUrl  String?
  accredibleId    String?         @unique
  verificationUrl String?
  credentialData  String?
  course          Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, certificateType])
  @@index([accredibleId])
}

model ForumPost {
  id        String       @id @default(cuid())
  title     String
  content   String
  userId    String
  courseId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   ForumReply[]
}

model ForumReply {
  id        String    @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserGamification {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalXP        Int      @default(0)
  currentLevel   Int      @default(1)
  currentStage   Int      @default(1)
  stageTitle     String   @default("Seeker")
  streakDays     Int      @default(0)
  lastActiveDate DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String        @id @default(cuid())
  name        String        @unique
  description String
  iconName    String
  category    BadgeCategory
  xpReward    Int           @default(0)
  rarity      BadgeRarity   @default(COMMON)
  criteria    String
  createdAt   DateTime      @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  progress Int      @default(100)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Skill {
  id            String          @id @default(cuid())
  name          String          @unique
  description   String
  iconName      String
  category      String
  parentSkillId String?
  moduleIds     String[]
  requiredXP    Int             @default(100)
  orderIndex    Int             @default(0)
  createdAt     DateTime        @default(now())
  parentSkill   Skill?          @relation("SkillHierarchy", fields: [parentSkillId], references: [id])
  childSkills   Skill[]         @relation("SkillHierarchy")
  progress      SkillProgress[]
}

model SkillProgress {
  id            String   @id @default(cuid())
  userId        String
  skillId       String
  xpEarned      Int      @default(0)
  isUnlocked    Boolean  @default(false)
  isMastered    Boolean  @default(false)
  lastPracticed DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model Checkpoint {
  id              String           @id @default(cuid())
  moduleId        String
  name            String
  description     String
  orderIndex      Int
  xpReward        Int              @default(50)
  requiredScore   Int              @default(70)
  createdAt       DateTime         @default(now())
  userCheckpoints UserCheckpoint[]
}

model UserCheckpoint {
  id           String     @id @default(cuid())
  userId       String
  checkpointId String
  isCompleted  Boolean    @default(false)
  score        Int?
  attempts     Int        @default(0)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  checkpoint   Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkpointId])
}

model MasteryRecord {
  id              String   @id @default(cuid())
  userId          String
  moduleId        String
  masteryLevel    Int      @default(0)
  assessmentScore Int      @default(0)
  timeInvested    Int      @default(0)
  practiceCount   Int      @default(0)
  lastPracticed   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model StageRequirement {
  id               String   @id @default(cuid())
  stage            Int      @unique
  title            String
  description      String
  requiredXP       Int
  requiredBadges   String[]
  requiredSkills   String[]
  capstoneModuleId String?
  createdAt        DateTime @default(now())
}

model TokenTransaction {
  id        String    @id @default(cuid())
  userId    String
  amount    Int
  tokenType TokenType @default(SAGE)
  reason    String
  metadata  String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TokenBalance {
  id               String   @id @default(cuid())
  userId           String   @unique
  sageTokens       Int      @default(0)
  reflectionTokens Int      @default(0)
  lifetimeTokens   Int      @default(0)
  lastUpdated      DateTime @default(now())

  @@index([userId])
}

model Pillar {
  id                         String     @id @default(cuid())
  code                       String     @unique
  name                       String
  description                String
  irreplaceabilityMultiplier Float
  examples                   String[]
  orderIndex                 Int
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
  activities                 Activity[]
}

model LearningPath {
  id                   String             @id @default(cuid())
  code                 String             @unique
  name                 String
  description          String
  pathWeightMultiplier Float
  focusAreas           String[]
  createdAt            DateTime           @default(now())
  userPaths            UserLearningPath[]
}

model UserLearningPath {
  id         String       @id @default(cuid())
  userId     String
  pathId     String
  isPrimary  Boolean      @default(true)
  selectedAt DateTime     @default(now())
  path       LearningPath @relation(fields: [pathId], references: [id])
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
}

model ActivityCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String
  basePoints  Int        @default(10)
  iconName    String
  pillars     String[]
  createdAt   DateTime   @default(now())
  activities  Activity[]
}

model Activity {
  id            String           @id @default(cuid())
  userId        String
  categoryId    String
  pillarId      String
  title         String
  description   String
  activityType  ActivityType
  hoursSpent    Float            @default(0)
  reach         Int?
  evidence      String?
  metadata      String?
  status        ActivityStatus   @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  category      ActivityCategory @relation(fields: [categoryId], references: [id])
  pillar        Pillar           @relation(fields: [pillarId], references: [id])
  user          User             @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)
  contributions Contribution[]
  verifications Verification[]

  @@index([userId, status])
  @@index([createdAt])
}

model Contribution {
  id                         String   @id @default(cuid())
  activityId                 String
  userId                     String
  basePoints                 Float
  irreplaceabilityMultiplier Float
  impactMultiplier           Float
  pathWeightMultiplier       Float
  verificationMultiplier     Float    @default(0.8)
  svuEarned                  Float
  calculatedAt               DateTime @default(now())
  activity                   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user                       User     @relation("UserContributions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([calculatedAt])
}

model Verification {
  id               String             @id @default(cuid())
  activityId       String
  verifierId       String?
  verificationType VerificationType
  status           VerificationStatus @default(PENDING)
  evidence         String?
  notes            String?
  impactScore      Float?
  submittedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  activity         Activity           @relation(fields: [activityId], references: [id], onDelete: Cascade)
  verifier         User?              @relation("VerifierActivities", fields: [verifierId], references: [id])

  @@index([status])
}

model SVUBalance {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalSVU     Float    @default(0)
  availableSVU Float    @default(0)
  usedSVU      Float    @default(0)
  verifiedSVU  Float    @default(0)
  lifetimeSVU  Float    @default(0)
  lastUpdated  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EarnDownRecord {
  id                 String    @id @default(cuid())
  userId             String
  courseId           String
  originalPrice      Float
  svuApplied         Float
  conversionRate     Float     @default(100)
  discountAmount     Float
  finalPrice         Float
  maxDiscountPercent Float     @default(70)
  appliedAt          DateTime  @default(now())
  expiresAt          DateTime?
  course             Course    @relation("CourseEarnDowns", fields: [courseId], references: [id], onDelete: Cascade)
  user               User      @relation("UserEarnDowns", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
}

model SAGEDToken {
  id                 String          @id @default(cuid())
  userId             String
  amount             Float           @default(0)
  sourceType         TokenSourceType
  sourceActivityId   String?
  conversionRate     Float           @default(1.0)
  eligibilityPercent Float           @default(100)
  mintedAt           DateTime        @default(now())
  walletAddress      String?
  txHash             String?
  user               User            @relation("UserSAGEDTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mintedAt])
}

model ResilienceScore {
  id                  String   @id @default(cuid())
  userId              String   @unique
  overallScore        Float    @default(0)
  symbolicScore       Float    @default(0)
  adaptiveScore       Float    @default(0)
  governanceScore     Float    @default(0)
  equityScore         Float    @default(0)
  defensiveScore      Float    @default(0)
  automationRiskLevel String   @default("MODERATE")
  lastCalculated      DateTime @default(now())
  trendDirection      String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdaptationReport {
  id                   String   @id @default(cuid())
  year                 Int      @unique
  automationTrends     String
  pillarAdjustments    String
  skillRecommendations String
  generatedAt          DateTime @default(now())
}

model CommunityImpact {
  id                  String         @id @default(cuid())
  userId              String
  activityId          String         @unique
  impactCategory      ImpactCategory
  verifiedHours       Float
  organizationName    String?
  organizationLetter  String?
  impactReach         Int?
  sustainabilityScore Float?
  recordedAt          DateTime       @default(now())
  user                User           @relation("UserCommunityImpacts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([impactCategory])
}

model BlocksLesson {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  description      String?
  instructions     String?
  starterWorkspace Json?
  stageConfig      Json?
  blockConfig      Json?
  orderIndex       Int                @default(0)
  isPublished      Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  projects         BlocksProject[]
  submissions      BlocksSubmission[]
}

model BlocksProject {
  id            String              @id @default(cuid())
  lessonId      String
  userId        String
  workspace     Json
  generatedCode String?
  status        BlocksProjectStatus @default(DRAFT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  lesson        BlocksLesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions   BlocksSubmission[]

  @@unique([lessonId, userId])
}

model BlocksSubmission {
  id         String                 @id @default(cuid())
  lessonId   String
  projectId  String
  userId     String
  reflection String?
  feedback   String?
  grade      Int?
  status     BlocksSubmissionStatus @default(SUBMITTED)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  lesson     BlocksLesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  project    BlocksProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model YoungSagesApplication {
  id                 String            @id @default(cuid())
  childFirstName     String
  childLastName      String
  childAge           Int
  guardianName       String
  guardianEmail      String
  guardianPhone      String?
  country            String
  timezone           String?
  hasComputer        Boolean           @default(true)
  hasInternet        Boolean           @default(true)
  accessNotes        String?
  selfAwareness      Int
  agency             Int
  growth             Int
  ethics             Int
  design             Int
  whyJoin            String
  priorExperience    String?
  learningGoals      String?
  parentalConsent    Boolean           @default(false)
  mediaConsent       Boolean           @default(false)
  rulesAccepted      Boolean           @default(false)
  status             ApplicationStatus @default(PENDING)
  adminNotes         String?
  needsEmailFollowup Boolean           @default(true)
  emailSentAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  reviewedAt         DateTime?
  reviewedBy         String?

  @@index([status])
  @@index([guardianEmail])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  source         String?
  interests      String[]
  isVerified     Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  unsubscribedAt DateTime?

  @@index([email])
  @@index([source])
  @@index([createdAt])
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AssignmentType {
  QUIZ
  PROJECT
  ESSAY
  CODE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

enum CertificateType {
  COURSE
  STAGE
  LEVEL
  SPECIAL
}

enum BadgeCategory {
  COMPLETION
  MASTERY
  COMMUNITY
  STREAK
  MILESTONE
  CAPSTONE
  SPECIAL
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum TokenType {
  SAGE
  REFLECTION
}

enum ActivityType {
  TEACHING
  MENTORING
  BUILDING
  STORYTELLING
  COMMUNITY_SERVICE
  FAITH_SERVICE
  NGO_PROJECT
  CIVIC_ENGAGEMENT
  CULTURAL_PRESERVATION
  TECHNICAL_BUILD
  RESEARCH
  CONTENT_CREATION
}

enum ActivityStatus {
  PENDING
  VERIFIED
  REJECTED
  IN_REVIEW
}

enum VerificationType {
  SELF_REPORTED
  PEER_REVIEW
  ORG_LETTER
  PHOTO_VIDEO
  CERTIFICATE
  AI_VALIDATED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
}

enum TokenSourceType {
  ACADEMIC
  TECHNICAL
  VOLUNTEER
  CULTURAL
  ROUTINE
}

enum ImpactCategory {
  COMMUNITY_SERVICE
  FAITH_BASED
  NGO_NONPROFIT
  CIVIC_ENGAGEMENT
  CULTURAL_PRESERVATION
}

enum BlocksProjectStatus {
  DRAFT
  SUBMITTED
}

enum BlocksSubmissionStatus {
  SUBMITTED
  REVIEWED
  RETURNED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  WAITLISTED
  REJECTED
}
